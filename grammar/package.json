{
  "name": "tree-sitter-nanoc",
  "version": "0.1.0",
  "description": "a simple systems PL targeting RISC-V and xv6",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+github.com/vincent-lafouasse/nanoc.git"
  },
  "funding": "",
  "license": "WTFPL",
  "author": {
    "name": "Vincent Lafouasse",
    "url": "github.com/vincent-lafouasse"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "nanoc"
